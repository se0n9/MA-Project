/*
 * COMPASS / Project HYBE - board overlay for the nRF52840DK.
 *
 * Declares the HT16K33 16x8 LED matrix on i2c0 (I2C address 0x70). led_display.c
 * binds to this node via DT_COMPAT_GET_ANY_STATUS_OKAY(holtek_ht16k33) and draws
 * the accumulated attendance count on it. The TM1651 battery bar is bit-banged
 * straight on gpio1 (P1.12/P1.13) from led_display.c, so it needs no DT node.
 *
 * SPDX-License-Identifier: Apache-2.0
 */

&i2c0 {
	clock-frequency = <I2C_BITRATE_STANDARD>;

	ht16k33@70 {
		compatible = "holtek,ht16k33";
		reg = <0x70>;
		/* Uncomment to use IRQ instead of polling: */
		/* irq-gpios = <&gpio1 8 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>; */
	};
};
